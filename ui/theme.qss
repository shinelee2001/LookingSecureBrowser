QMainWindow {
    background-color: #050805;
}

QWidget {
    background-color: #050805;
    color: #d8ffe8;
    font-family: Consolas, "Courier New", monospace;
    font-size: 13px;
}

QLineEdit {
    background-color: #0b120d;
    color: #00ff88;
    border: 1px solid #00aa55;
    padding: 8px;
    selection-background-color: #00ff88;
    selection-color: #000000;
}

QPushButton {
    background-color: #0b120d;
    color: #00ff88;
    border: 1px solid #00aa55;
    padding: 8px 12px;
}

QPushButton:hover {
    background-color: #102018;
    border: 1px solid #00ff88;
}

#ConsoleToolButton {
    padding: 3px 8px;
    font-size: 12px;
}

QTextEdit {
    background-color: #020402;
    color: #00ff88;
    border: 1px solid #00aa55;
    padding: 10px;
}

QTableWidget {
    background-color: #020402;
    color: #d8ffe8;
    border: 1px solid #00aa55;
    selection-background-color: #123b25;
    selection-color: #ffffff;
}

QHeaderView::section {
    background-color: #0b120d;
    color: #00ff88;
    border: 0;
    border-bottom: 1px solid #00aa55;
    padding: 6px 8px;
    font-weight: bold;
}

QLabel {
    color: #d8ffe8;
}

#SecurityPanel {
    background-color: #080f0a;
    border-left: 1px solid #00aa55;
}

#SecuritySummaryBar {
    background-color: #020402;
    border-bottom: 1px solid #00aa55;
}

#PanelTitle {
    color: #00ff88;
    font-size: 14px;
    font-weight: bold;
    padding: 0;
}

#SubPanelTitle {
    color: #d8ffe8;
    font-size: 13px;
    font-weight: bold;
    padding: 4px 2px;
}

#NetworkPanel {
    background-color: #080f0a;
}

#FindingsPanel {
    background-color: #080f0a;
}

#ScoreLabel {
    color: #00ff88;
    font-size: 13px;
    font-weight: bold;
}

#GradeLabel {
    color: #ffcc00;
    font-size: 13px;
    font-weight: bold;
}

#BlockedLabel {
    color: #ff6666;
    font-size: 13px;
    font-weight: bold;
}

#AllowedLabel {
    color: #00ff88;
    font-size: 13px;
    font-weight: bold;
}
